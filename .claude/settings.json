{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "includeCoAuthoredBy": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(dotnet build*)",
      "Bash(dotnet run*)",
      "Bash(dotnet test*)",
      "Bash(dotnet ef*)",
      "Bash(dotnet add*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet format*)",
      "Bash(npm run*)",
      "Bash(npm install*)",
      "Bash(npm ci)",
      "Bash(npx*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose build*)",
      "Bash(docker ps*)",
      "Bash(curl http://localhost*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(touch*)",
      "Bash(echo*)",
      "Bash(cp*)",
      "Bash(mv*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(docker compose down -v*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./backend/**/appsettings.Development.json)",
      "Read(./frontend/.env.local)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_FILE\" == *.cs ]]; then cd backend && dotnet format --include \"$CLAUDE_TOOL_FILE\" 2>/dev/null; fi"
          },
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_FILE\" == *.ts || \"$CLAUDE_TOOL_FILE\" == *.tsx ]]; then cd frontend && npx prettier --write \"$CLAUDE_TOOL_FILE\" 2>/dev/null; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "grep -q 'rm -rf /' <<< \"$CLAUDE_TOOL_INPUT\" && exit 2 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && dotnet build --no-restore -v quiet 2>&1 | grep -E '^.*error' | head -5 || true"
          }
        ]
      }
    ]
  }
}
